# BiblioDrift Environment Configuration Example
# Copy this file to .env and customize for your environment

# Application Environment (development, production, testing)
APP_ENV=development
# =============================================================================
# SECURITY: Credential Encryption (Recommended for Production)
# =============================================================================
# To encrypt sensitive API keys, use the security_utils module:
#   from security_utils import encrypt_credential
#   encrypted_key = encrypt_credential("your-actual-api-key")
#
# Then set CREDENTIAL_MASTER_PASSWORD to enable decryption at runtime.
# This prevents storing plain-text credentials in .env files.
# =============================================================================

# Master password for encrypting/decrypting credentials (OPTIONAL but RECOMMENDED)
# Generate a secure password using: python -c "from security_utils import CredentialEncryption; print(CredentialEncryption.generate_master_password())"
CREDENTIAL_MASTER_PASSWORD=your_secure_master_password_here

# Google Books API Key
GOOGLE_BOOKS_API_KEY=your_google_id_here

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
JWT_ALGORITHM=HS256

# Database Configuration
DATABASE_URL=sqlite:///instance/biblio.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Server Configuration
FLASK_HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=True

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=True
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE=logs/bibliodrift.log

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# LLM Configuration
PREFERRED_LLM=groq
OPENAI_MODEL=gpt-3.5-turbo
GROQ_MODEL=openai/gpt-oss-20b
GEMINI_MODEL=gemini-1.5-flash
DEFAULT_MAX_TOKENS=150
BOOK_NOTE_MAX_TOKENS=100
RECOMMENDATION_MAX_TOKENS=150

# Purchase Links Configuration
AMAZON_AFFILIATE_TAG=your_amazon_affiliate_tag
FLIPKART_AFFILIATE_ID=your_flipkart_affiliate_id
BARNES_NOBLE_AFFILIATE_ID=your_barnes_noble_affiliate_id
PURCHASE_LINKS_CACHE_TTL=3600

# Caching Configuration (if using caching features)
# CACHE_TYPE=simple
# REDIS_URL=redis://localhost:6379/0
# CACHE_MOOD_ANALYSIS_TTL=86400
# CACHE_RECOMMENDATIONS_TTL=3600
# CACHE_MOOD_TAGS_TTL=43200
# CACHE_CHAT_RESPONSE_TTL=1800
# CACHE_GOODREADS_TTL=604800
# CACHE_DEFAULT_TIMEOUT=3600
PURCHASE_LINKS_TIMEOUT=10
PURCHASE_LINKS_MAX_RETRIES=3
PURCHASE_LINKS_RETRY_DELAY=1.0
PURCHASE_LINKS_MAX_CONCURRENT=4
PURCHASE_LINKS_LOG_LEVEL=INFO

# =============================================================================
# Bruno API Collection Configuration (Optional)
# =============================================================================
# These variables are used by Bruno API testing collection
# NEVER commit actual values to version control
# Store actual credentials in bruno/environments/local.bru (gitignored)
# =============================================================================

# BiliBili Authentication (for API testing with Bruno)
phone=your_phone_number
pwd=your_password
mid=your_mid_value
buvid=your_buvid_value
csrf=your_csrf_token

# BiliBili API Credentials
appKey=your_app_key_here
access_key=your_access_key_here

# Session Data
cookieStr=your_cookie_string_here
bili_ticket=your_jwt_token_here
