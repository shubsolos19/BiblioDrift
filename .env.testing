# Testing Environment Configuration

# Application Environment
APP_ENV=testing

# JWT Configuration
JWT_SECRET_KEY=test-secret-key-for-testing-only
JWT_ACCESS_TOKEN_EXPIRES_DAYS=1
JWT_ALGORITHM=HS256

# Database Configuration (In-memory for tests)
DATABASE_URL=sqlite:///:memory:
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Server Configuration
FLASK_HOST=127.0.0.1
PORT=5001
FLASK_DEBUG=False

# Rate Limiting Configuration (Disabled for tests)
RATE_LIMIT_ENABLED=False
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=1000

# Logging Configuration
LOG_LEVEL=ERROR
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# AI Service Configuration (Mock values for testing)
OPENAI_API_KEY=test-openai-key
GROQ_API_KEY=test-groq-key
GEMINI_API_KEY=test-gemini-key
GOOGLE_BOOKS_API_KEY=test-google-books-key